# =============================================================================
# IQBANDIT — environment variable reference
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =============================================================================

# Admin credentials (single-admin MVP)
STARTCLAW_ADMIN_EMAIL=admin@example.com
STARTCLAW_ADMIN_PASSWORD=

# Session signing secret — generate with: openssl rand -base64 32
STARTCLAW_SESSION_SECRET=

# OpenClaw gateway (server-side only — never exposed to the browser)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:19001
OPENCLAW_GATEWAY_TOKEN=

# Chat mode — "openclaw" or "disabled"
STARTCLAW_CHAT_MODE=openclaw

# Public app URL (used in OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Token encryption secret — generate with: openssl rand -base64 32
INTEGRATIONS_ENCRYPTION_SECRET=

# Gmail OAuth (Google Cloud Console → APIs & Services → Credentials)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3000/api/integrations/oauth/gmail/callback

# mcp-gmail token sync
MCP_GMAIL_TOKEN_DB_PATH=
GMAIL_ACCOUNT_ID=default

# =============================================================================
# SAAS PROVISIONING — Container + VPS management
# =============================================================================

# Contabo VPS that hosts all Starter-tier containers
VPS_HOST=
VPS_SSH_USER=root
# Base64-encoded private key: cat ~/.ssh/id_rsa | base64 | tr -d '\n'
VPS_SSH_PRIVATE_KEY=

# Contabo API — used for Pro tier dedicated VPS provisioning
CONTABO_CLIENT_ID=
CONTABO_CLIENT_SECRET=
CONTABO_API_USER=
CONTABO_API_PASSWORD=
CONTABO_PRODUCT_ID=V45
CONTABO_REGION=EU

# Search infrastructure (internal Docker network URLs)
SEARCH_SERVICE_URL=http://iqbandit-search:9000
SEARXNG_URL=http://iqbandit-searxng:8080

# =============================================================================
# SOCIAL MEDIA / BYOK CREDENTIALS
# =============================================================================

# AES-256-CBC key for encrypting social media API keys at rest in SQLite.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# =============================================================================
# STRIPE — billing and subscription management
# =============================================================================
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIG_ID=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
STRIPE_PRICE_BANDIT_PLUS_MONTHLY=
STRIPE_PRICE_BANDIT_PLUS_ANNUAL=

# =============================================================================
# GOOGLE OAUTH — "Sign in with Google" for user authentication
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
